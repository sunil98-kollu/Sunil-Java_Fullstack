package com.org.Al;

import java.util.HashMap;
import java.util.Map;


public class HashMapAcc {
	 String accountHolderName;
	    double balance;
	    String branch;

	    HashMapAcc(String accountHolderName, double balance, String branch) {
	        this.accountHolderName = accountHolderName;
	        this.balance = balance;
	        this.branch = branch;
	    }

	    void display(String accNumber) {
	        System.out.println(accNumber + " | " + accountHolderName + " | ₹" 
	                + balance + " | " + branch);
	    }

	    public static void main(String[] args) {

	        HashMap<String, HashMapAcc> map = new HashMap<>();

	        //  Add accounts
	        map.put("ACC101", new HashMapAcc("Sunil", 15000, "Hyderabad"));
	        map.put("ACC102", new HashMapAcc("Ravi", 8000, "Chennai"));
	        map.put("ACC103", new HashMapAcc("Anil", 5000, "Bangalore"));
	        map.put("ACC104", new HashMapAcc("Priya", 20000, "Mumbai"));
	        map.put("ACC105", new HashMapAcc("Neha", 12000, "Delhi"));

	        // 2️⃣ Display all accounts
	        System.out.println("All Accounts:");
	        for (Map.Entry<String, HashMapAcc> entry : map.entrySet()) {
	            entry.getValue().display(entry.getKey());
	        }

	        // 3️⃣ Search account
	        String searchAcc = "ACC102";

	        System.out.println("\nSearch Result:");
	        if (map.containsKey(searchAcc)) {
	            map.get(searchAcc).display(searchAcc);
	        } else {
	            System.out.println("Account not found");
	        }

	        // 4️⃣ Deposit (update balance)
	        String depositAcc = "ACC103";
	        double depositAmount = 2000;

	        if (map.containsKey(depositAcc)) {
	        	HashMapAcc acc = map.get(depositAcc);
	            acc.balance += depositAmount;
	            System.out.println("\nUpdated Balance for " + depositAcc + ": ₹" + acc.balance);
	        }

	        // 5️⃣ Remove closed account
	        String closedAcc = "ACC105";
	        map.remove(closedAcc);

	        // 6️⃣ Display updated list
	        System.out.println("\nUpdated Account List:");
	        for (Map.Entry<String, HashMapAcc> entry : map.entrySet()) {
	            entry.getValue().display(entry.getKey());
	        }
	    }
}



