    public ResponseEntity<Customer> getCustomer(){

        Customer c1 = new Customer(1, "John", "john@gmail.com");

        return new ResponseEntity<>(c1, HttpStatus.OK);
    }

    @GetMapping(value="/customers", produces = "application/json")
