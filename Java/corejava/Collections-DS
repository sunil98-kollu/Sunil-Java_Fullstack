classListIteratorDemo { 
 public static void main(String[] args) { 
  LinkedList l = new LinkedList(); 
  l.add("Baala"); 
  l.add("Venki"); 
  l.add("Chiru"); 
  l.add("Naag"); 
  System.out.println(l); 
  ListIteratorltr = l.listIterator(); 
  while(ltr.hasNext()) { 
